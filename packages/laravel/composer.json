{
  "name": "kushal-khadka/universal-sambat-sdk",
  "description": "Bikram Sambat (BS) Nepali date picker for Laravel — Blade components, validation rules, and pure PHP BS/AD conversion.",
  "type": "library",
  "license": "MIT",
  "version": "1.2.0",
  "keywords": ["nepali", "datepicker", "bikram-sambat", "bs-date", "laravel", "blade"],
  "authors": [
    {
      "name": "Kushal Khadka",
      "email": "kushalkhadkaa@gmail.com"
    }
  ],
  "require": {
    "php": "^8.0",
    "illuminate/support": "^9.0|^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "KushalKhadka\\NepaliDatePicker\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "KushalKhadka\\NepaliDatePicker\\NepaliDatePickerServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
